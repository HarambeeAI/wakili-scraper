# Frontend environment variables for Railway deployment
# These are baked into the JS bundle at build time by Vite

# Railway API Server URL (e.g., https://api-server-production-xxxx.up.railway.app)
VITE_API_URL=

# Logto OIDC configuration
VITE_LOGTO_ENDPOINT=
VITE_LOGTO_APP_ID=
VITE_LOGTO_API_RESOURCE=

# LangGraph Server URL (if direct access needed, otherwise proxied via VITE_API_URL)
VITE_LANGGRAPH_URL=

# VAPID public key for push notifications
VITE_VAPID_PUBLIC_KEY=

# --- REMOVED (no longer needed) ---
# VITE_SUPABASE_URL (removed — replaced by VITE_API_URL)
# VITE_SUPABASE_PUBLISHABLE_KEY (removed — replaced by Logto)
# VITE_SUPABASE_PROJECT_ID (removed)
