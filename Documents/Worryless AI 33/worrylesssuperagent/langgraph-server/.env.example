# Supabase PostgreSQL connection (direct, not pooled — PostgresSaver needs prepared statements)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# Supabase service role key (for Store operations and RLS bypass)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Supabase project URL
SUPABASE_URL=https://[PROJECT_REF].supabase.co

# Server port
PORT=3001

# LLM API key (required for all agent graphs in Phase 11+)
LOVABLE_API_KEY=your-lovable-api-key-here
